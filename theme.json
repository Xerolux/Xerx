{
  "version": 3,
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "blank",
      "title": "Blank",
      "postTypes": [ "page", "post" ]
    },
    {
      "name": "no-header",
      "title": "No Header",
      "postTypes": [ "page" ]
    },
    {
      "name": "landing",
      "title": "Landing",
      "postTypes": [ "page" ]
    },
    {
      "name": "focus",
      "title": "Focus Reading",
      "postTypes": [ "post", "page" ]
    },
    {
      "name": "no-footer",
      "title": "No Footer",
      "postTypes": [ "page", "post" ]
    }
  ],
  "settings": {
    "appearanceTools": true,
    "custom": {
      "radius": {
        "s": "4px",
        "m": "10px",
        "l": "18px",
        "pill": "999px"
      }
    },
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1080px"
    },
    "spacing": {
      "customSpacingSize": true,
      "defaultSpacingSizes": false,
      "units": [ "px", "%", "em", "rem", "vw", "vh" ],
      "spacingSizes": [
        { "name": "2XS", "slug": "10", "size": "0.25rem" },
        { "name": "XS",  "slug": "20", "size": "0.5rem" },
        { "name": "S",   "slug": "30", "size": "0.75rem" },
        { "name": "M",   "slug": "40", "size": "1rem" },
        { "name": "L",   "slug": "50", "size": "1.5rem" },
        { "name": "XL",  "slug": "60", "size": "2rem" },
        { "name": "2XL", "slug": "70", "size": "3rem" },
        { "name": "3XL", "slug": "80", "size": "4rem" },
        { "name": "4XL", "slug": "90", "size": "6rem" },
        { "name": "5XL", "slug": "100", "size": "8rem" }
      ]
    },
    "dimensions": {
      "minHeight": true
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "name": "Subtle Surface",
          "slug": "subtle",
          "shadow": "0 1px 2px rgba(17,49,24,0.08), 0 8px 24px rgba(0,0,0,0.06)"
        },
        {
          "name": "Lifted",
          "slug": "medium",
          "shadow": "0 8px 24px rgba(0,0,0,0.14)"
        },
        {
          "name": "Large Lift",
          "slug": "large",
          "shadow": "0 14px 40px rgba(0,0,0,0.2)"
        },
        {
          "name": "Inner Border",
          "slug": "inset",
          "shadow": "inset 0 0 0 1px rgba(17,49,24,0.18)"
        }
      ]
    },
    "typography": {
      "fluid": {
        "minViewportWidth": "320px",
        "maxViewportWidth": "1440px"
      },
      "customFontSize": true,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "name": "Body",
          "slug": "body",
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        },
        {
          "name": "Sans",
          "slug": "body-alt",
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        },
        {
          "name": "Heading",
          "slug": "heading",
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
        },
        {
          "name": "Display Serif",
          "slug": "display",
          "fontFamily": "'Cormorant Garamond', 'IBM Plex Serif', Georgia, serif"
        },
        {
          "name": "Monospace",
          "slug": "mono",
          "fontFamily": "'JetBrains Mono', 'IBM Plex Mono', 'Fira Code', Consolas, monospace"
        }
      ],
      "fontSizes": [
        {
          "name": "X-Small",
          "slug": "x-small",
          "size": "0.8125rem",
          "fluid": { "min": "0.78rem", "max": "0.875rem" }
        },
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem",
          "fluid": { "min": "0.8rem", "max": "0.875rem" }
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem",
          "fluid": false
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.25rem",
          "fluid": { "min": "1.125rem", "max": "1.35rem" }
        },
        {
          "name": "X-Large",
          "slug": "x-large",
          "size": "1.75rem",
          "fluid": { "min": "1.4rem", "max": "2rem" }
        },
        {
          "name": "XX-Large",
          "slug": "xx-large",
          "size": "2.5rem",
          "fluid": { "min": "1.75rem", "max": "3rem" }
        },
        {
          "name": "Display",
          "slug": "display",
          "size": "3.75rem",
          "fluid": { "min": "2.1rem", "max": "4.6rem" }
        }
      ]
    },
    "color": {
      "custom": true,
      "customGradient": true,
      "defaultPalette": false,
      "defaultGradients": false,
      "duotone": [
        {
          "name": "Dark Green on Ecru",
          "slug": "dark-green-on-ecru",
          "colors": [ "#113118", "#E1D9D3" ]
        },
        {
          "name": "Dark Blue on Sky Blue",
          "slug": "dark-blue-on-sky-blue",
          "colors": [ "#283D5D", "#BADCE0" ]
        }
      ],
      "palette": [
        { "name": "Surface", "slug": "surface", "color": "#FCFBF9" },
        { "name": "Surface Alt", "slug": "surface-alt", "color": "#F4EFEA" },
        { "name": "Text", "slug": "text", "color": "#1D1D1B" },
        { "name": "Muted", "slug": "muted", "color": "#5C5A56" },
        { "name": "Accent", "slug": "accent", "color": "#6D3F3E" },
        { "name": "Accent Cool", "slug": "accent-cool", "color": "#355478" },
        { "name": "Brick",      "slug": "brick",      "color": "#825A58" },
        { "name": "Baby Pink",  "slug": "baby-pink",  "color": "#E0BAC0" },
        { "name": "Ecru",       "slug": "ecru",       "color": "#E1D9D3" },
        { "name": "Peach",      "slug": "peach",      "color": "#E6AA88" },
        { "name": "Sky Blue",   "slug": "sky-blue",   "color": "#BADCE0" },
        { "name": "Green",      "slug": "green",      "color": "#81AE8A" },
        { "name": "Olive",      "slug": "olive",      "color": "#959686" },
        { "name": "Dark Green", "slug": "dark-green", "color": "#113118" },
        { "name": "Dark Blue",  "slug": "dark-blue",  "color": "#283D5D" },
        { "name": "Light Gray", "slug": "light-gray", "color": "#eaeaea" },
        { "name": "Dark Gray",  "slug": "dark-gray",  "color": "#222222" },
        { "name": "White",      "slug": "white",      "color": "#ffffff" },
        { "name": "Black",      "slug": "black",      "color": "#000000" },
        { "name": "Indigo",     "slug": "indigo",     "color": "#6366f1" },
        { "name": "Slate",      "slug": "slate",      "color": "#1e293b" }
      ],
      "gradients": [
        {
          "name": "Warm Paper",
          "slug": "ecru-to-white",
          "gradient": "linear-gradient(135deg, #F4EFEA 0%, #FCFBF9 100%)"
        },
        {
          "name": "Green to Sky Blue",
          "slug": "green-to-sky-blue",
          "gradient": "linear-gradient(135deg, #81AE8A 0%, #BADCE0 100%)"
        },
        {
          "name": "Copper to Blush",
          "slug": "copper-to-blush",
          "gradient": "linear-gradient(135deg, #825A58 0%, #E0BAC0 100%)"
        },
        {
          "name": "Deep Sea",
          "slug": "deep-sea",
          "gradient": "linear-gradient(135deg, #113118 0%, #283D5D 100%)"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "color": {
          "defaultPalette": false
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body-alt)",
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "core/image": {
        "lightbox": {
          "enabled": true,
          "allowEditing": true
        }
      },
      "core/post-featured-image": {
        "dimensions": {
          "aspectRatio": true
        }
      }
    }
  },
  "styles": {
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--50)",
      "padding": {
        "left": "clamp(1rem, 2vw, 2rem)",
        "right": "clamp(1rem, 2vw, 2rem)"
      }
    },
    "color": {
      "background": "var(--wp--preset--color--surface)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.72",
      "letterSpacing": "0.005em"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--display)",
          "lineHeight": "1.04",
          "letterSpacing": "-0.015em"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "lineHeight": "1.15",
          "letterSpacing": "-0.01em"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "lineHeight": "1.25"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--large)",
          "lineHeight": "1.3"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--medium)",
          "lineHeight": "1.35"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--small)",
          "lineHeight": "1.4",
          "textTransform": "uppercase",
          "letterSpacing": "0.08em"
        }
      },
      "link": {
        "color": {
          "text": "#6366f1"
        },
        ":hover": {
          "color": {
            "text": "#4f46e5"
          }
        },
        ":focus": {
          "outline": {
            "color": "var(--wp--preset--color--dark-blue)",
            "style": "solid",
            "width": "2px",
            "offset": "2px"
          }
        }
      },
      "button": {
        "border": {
          "radius": "8px"
        },
        "color": {
          "background": "#6366f1",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontSize": "var(--wp--preset--font-size--small)"
        },
        ":hover": {
          "color": {
            "background": "#4f46e5"
          }
        },
        ":focus": {
          "outline": {
            "color": "var(--wp--preset--color--sky-blue)",
            "style": "solid",
            "width": "2px",
            "offset": "2px"
          }
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--pill)"
        }
      },
      "core/code": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)"
        },
        "color": {
          "background": "#1e293b",
          "text": "#e2e8f0"
        },
        "border": {
          "radius": "8px"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--40)",
            "bottom": "var(--wp--preset--spacing--40)",
            "left": "var(--wp--preset--spacing--50)",
            "right": "var(--wp--preset--spacing--50)"
          }
        }
      },
      "core/preformatted": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)"
        }
      },
      "core/quote": {
        "border": {
          "color": "var(--wp--preset--color--indigo)",
          "style": "solid",
          "width": "3px"
        },
        "spacing": {
          "padding": {
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)"
        }
      },
      "core/pullquote": {
        "border": {
          "color": "var(--wp--preset--color--indigo)",
          "style": "solid",
          "top": { "width": "2px" },
          "bottom": { "width": "2px" }
        },
        "color": {
          "text": "var(--wp--preset--color--indigo)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontStyle": "normal"
        }
      },
      "core/navigation": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--40)"
        },
        "typography": {
          "textTransform": "uppercase",
          "fontWeight": "600",
          "letterSpacing": "0.03em"
        }
      },
      "core/navigation-link": {
        "typography": {
          "textDecoration": "none"
        }
      },
      "core/group": {
        "border": {
          "radius": "var(--wp--custom--radius--m)"
        }
      },
      "core/columns": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--50)"
        }
      },
      "core/table": {
        "border": {
          "color": "var(--wp--preset--color--light-gray)",
          "style": "solid",
          "width": "1px"
        }
      },
      "core/post-featured-image": {
        "border": {
          "radius": "var(--wp--custom--radius--m)"
        }
      },
      "core/search": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body-alt)"
        }
      },
      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--light-gray)"
        }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontWeight": "500",
          "letterSpacing": "0.02em"
        }
      },
      "core/site-tagline": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body-alt)",
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "core/post-excerpt": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)"
        }
      },
      "core/post-date": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--x-small)",
          "letterSpacing": "0.06em",
          "textTransform": "uppercase"
        }
      },
      "core/post-author-name": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body-alt)",
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      }
    }
  }
}
